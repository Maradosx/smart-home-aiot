# ============================================================
# .env.example — Smart Home AIoT Project
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริงของคุณ
# ============================================================

# ─── Anthropic Claude API ────────────────────────────────────
CLAUDE_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx

# ─── LINE Messaging API ──────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# ─── n8n ─────────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=your_random_encryption_key_here

# ─── MQTT Server IP ──────────────────────────────────────────
MQTT_SERVER_IP=192.168.1.100

# ─── MQTT Auth ───────────────────────────────────────────────
MQTT_USERNAME=
MQTT_PASSWORD=
